# - name: window_xstop
#   datatype: int64
#   meta: !!omap
#   - {description: Maximum X position in pixels in the science coordinate frame of all                tracking guide windows in this
#       exposure.}
# - name: window_ystart
#   datatype: int64
#   meta: !!omap
#   - {description: Minimum Y position in pixels in the science coordinate frame of all                tracking guide windows in this
#       exposure.}
# - name: window_ystop
#   datatype: int64
#   meta: !!omap
