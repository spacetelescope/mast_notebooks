# - name: guide_star_id
#   datatype: string
#   meta: !!omap
#   - {description: Identification of the guide star from the Guide Star Catalog (GSC). This is                based on planned information
#       from the Roman Planning and Scheduling Subsystem.}
# - name: guide_window_id
#   datatype: string
