# - name: ephemeris_type
#   datatype: string
#   meta: !!omap
#   - {description: Type of ephemeris (either DEFINITIVE or PREDICTED).}
# - name: epoch
#   datatype: string
#   meta: !!omap
#   - {description: Epoch of the celestial coordinates of the guide star from the Guide Star                Catalog (GSC).}
# - name: good_pixel_fraction
#   datatype: float64
#   meta: !!omap
#   - {description: The fraction of pixels in the output image that are considered good.}
