#   - {description: guide_window_id}
# - name: image_median
#   datatype: float64
#   meta: !!omap
#   - {description: Median image value in units of megaJanskys per steradian (MJy/sr).}
# - name: image_rms
#   datatype: float64
#   meta: !!omap
#   - {description: Mean absolute deviation of the image values in units of data numbers per                second (DN/s).}
# - name: led
#   datatype: string
#   meta: !!omap
#   - {description: 'The light emitting diode (LED) passband selected in the program                specification in the Astronomer''s
#       Proposal Tool (APT). Values are integer strings                between ''1'' and ''6'' inclusive, when the RCS is on, and ''N/A''
#       when the RCS is off.'}
# - name: observation_id
#   datatype: string
#   meta: !!omap
#   - {description: 'The format of the programmatic observation identifier       is "PPPPPCCAAASSSOOOVVVggsaaeee" where "PPPPP" is the
#       program       number, "CC" is the execution plan number, "AAA" is the pass       number, "SSS" is the segment number, "OOO" is
#       the observation       number, "VVV" is the visit number, "gg" is the visit file group,       "s" is the visit file sequence, "aa"
#       is the visit file activity,       and "eeee" is the exposure number. The observation identifier is       the complete concatenation
#       of the visit_id +       visit_file_statement (visit_file_group + visit_file_sequence +       visit_file_activity) + exposure.
#       For spectral datasets, Observation ID of the last SOC-provided L2 spectral image used to create the file. Example value ''0000101001001001001'''}
# - name: pa_aperture
#   datatype: float64
#   meta: !!omap
#   - {description: Position angle in degrees of the aperture ideal Y axis relative to the V3                axis of the spacecraft. This
#       information comes from the Science Instrument Aperture                File (SIAF) in the Science Operations Center (SOC) Project
#       Reference Database (PRD).}
# - name: pa_v3
#   datatype: float64
#   meta: !!omap
#   - {description: The position angle of the V3 axis (in units of degrees) is defined as the                projection of the V3 axis
#       on the sky measured from North to East. The telescope V                coordinate system is defined with its origin at the vertex
#       of the primary mirror. The                +V3 axis is defined to be orthogonal to the sunshield. See Roman-STScI-000143                'Description
#       of the Roman SIAF and Coordinate Frames' for more information.}
# - name: pixel_area
#   datatype: float64
#   meta: !!omap
#   - {description: The average pixel area in units of steradians. This may be converted to                units of square arcseconds
#       by multiplying the value by 4.254517 x 10^10 square                arcseconds per steradian.}
# - name: pointing_engineering_source
#   datatype: string
#   meta: !!omap
#   - {description: 'The source type of the pointing information in the metadata may be set to                either ''PLANNED'' or ''CALCULATED''.
#       If the value is ''PLANNED'', then pointing mnemonics                were not found in the engineering database, and the pointing
#       data were taken from the                observation planning information. If the value is ''CALCULATED'', then the pointing                data
#       were determined using the information in the engineering database.'}
# - name: ra_reference
#   datatype: float64
#   meta: !!omap
#   - {description: Reference position right ascension corrected for velocity aberration in                units of degrees.}
# - name: ra_v1
#   datatype: float64
#   meta: !!omap
#   - {description: 'The right ascension coordinate of the V1 axis in units of degrees. This may                be considered the right
#       ascension coordinate of the telescope boresight. The                telescope V coordinate system is defined with its origin at
#       the vertex of the primary                mirror. The V1 axis is orthogonal to the primary mirror, parallel to the telescope                boresight,
#       and increasing positively through the telescope aperture. See                Roman-STScI-000143 ''Description of the Roman SIAF
#       and Coordinate Frames'' for more                information.'}
# - name: roll_ref
#   datatype: float64
#   meta: !!omap
#   - {description: Position angle of the telescope V3 axis at the reference pixel position                measured from North to East.
#       The telescope V coordinate system is defined with its                origin at the vertex of the primary mirror. The +V3 axis
#       is orthogonal to the                sunshield. See Roman-STScI-000143 'Description of the Roman SIAF and Coordinate                Frames'
#       for more information.}
# - name: scale_factor
#   datatype: float64
#   meta: !!omap
#   - {description: Scale factor used for the correction of the velocity aberration.}
# - name: sdf_software_version
#   datatype: string
#   meta: !!omap
#   - {description: The version number of the Science Operations Center (SOC) Science Data                Formatting (SDF) software used
#       in generating this file.}
# - name: spatial_x
#   datatype: float64
#   meta: !!omap
#   - {description: X barycentric coordinate of the Roman observatory at the MJD described by                meta.ephemeris.time.}
# - name: spatial_y
#   datatype: float64
#   meta: !!omap
#   - {description: Y barycentric coordinate of the Roman observatory at the MJD described by                meta.ephemeris.time.}
# - name: spatial_z
#   datatype: float64
#   meta: !!omap
#   - {description: Z barycentric coordinate of the Roman observatory at the MJD described by                meta.ephemeris.time.}
# - name: target_aperture
#   datatype: string
#   meta: !!omap
#   - {description: Name of the aperture used to align the instrument to a position on the sky.}
# - name: target_dec
#   datatype: float64
#   meta: !!omap
#   - {description: Declination in units of degrees at the location of the target aperture.}
# - name: target_ra
#   datatype: float64
#   meta: !!omap
#   - {description: Right ascension in units of degrees at the location of the target aperture.}
# - name: v2_ref
#   datatype: float64
#   meta: !!omap
#   - {description: 'Coordinate of the reference pixel position along the telescope V2 axis in                units of arcseconds. This
#       information comes from the Science Instrument Aperture File                (SIAF) in the Science Operations Center (SOC) Project
#       Reference Database (PRD). The                telescope V coordinate system is defined with its origin at the vertex of the primary                mirror.
#       The +V1 axis is defined as parallel to the telescope boresight, the +V3 axis                is orthogonal to the sunshield, and
#       the +V2 axis completes the right-hand system. See                Roman-STScI-000143 ''Description of the Roman SIAF and Coordinate
#       Frames'' for more                information.'}
# - name: v3_ref
#   datatype: float64
#   meta: !!omap
#   - {description: Coordinate of the reference pixel position along the telescope V3 axis in                units of arcseconds. This
#       information comes from the Science Instrument Aperture File                (SIAF) in the Science Operations Center (SOC) Project
#       Reference Database (PRD). The                telescope V coordinate system is defined with its origin at the vertex of the primary                mirror.
#       The +V3 axis is orthogonal to the sunshield. See Roman-STScI-000143                'Description of the Roman SIAF and Coordinate
#       Frames' for more information.}
# - name: v3yangle
#   datatype: float64
#   meta: !!omap
#   - {description: Angle between the telescope V3 axis and the ideal Y axis in units of                degrees. This information comes
#       from the Science Instrument Aperture File (SIAF) in                the Science Operations Center (SOC) Project Reference Database
#       (PRD). The telescope V                coordinate system is defined with its origin at the vertex of the primary mirror. The                +V3
#       axis is orthogonal to the sunshield. The ideal coordinate system is a                geomtric-distortion-corrected reference frame
#       projected onto a tangent plane. See                Roman-STScI-000143 'Description of the Roman SIAF and Coordinate Frames' for
#       more                information.}
# - name: velocity_x
#   datatype: float64
#   meta: !!omap
#   - {description: X component of the Roman velocity in a barycentric system in units of km/s                at the MJD described by
#       meta.ephemeris.time.}
# - name: velocity_y
#   datatype: float64
#   meta: !!omap
#   - {description: Y component of the Roman velocity in a barycentric system in units of km/s                at the MJD described by
#       meta.ephemeris.time.}
# - name: velocity_z
#   datatype: float64
#   meta: !!omap
#   - {description: Z component of the Roman velocity in a barycentric system in units of km/s                at the MJD described by
#       meta.ephemeris.time.}
# - name: visit_file_activity
#   datatype: string
#   meta: !!omap
#   - {description: The visit file activity number identifies the activity within the visit                file sequence. The allowed
#       range of visit file activity numbers is 01 to 99                inclusive.}
# - name: visit_file_group
#   datatype: int64
#   meta: !!omap
#   - {description: The visit file group identifies the sequence group within the visit file.                The allowed range of visit
#       file group numbers is 01 to 99 inclusive.}
# - name: visit_file_sequence
#   datatype: int64
#   meta: !!omap
#   - {description: 'The visit file sequence identifies the sequence within the visit file                group. A value of 1 indicates
#       a prime instrument exposure, and a value greater than 1                indicates a parallel instrument exposure. The allowed range
#       of visit file sequence                numbers of 1 to 5 inclusive.'}
# - name: visit_id
#   datatype: string
#   meta: !!omap
#   - {description: 'A unique identifier for a visit. The format is ''PPPPPCCAAASSSOOOVVV'' where                ''PPPPP'' is the program
#       number, ''CC'' is the execution plan number, ''AAA'' is the pass                number, ''SSS'' is the segment number, ''OOO''
#       is the observation number, and ''VVV'' is                the visit number.'}
# - name: visit_internal_target
#   datatype: string
#   meta: !!omap
#   - {description: 'A boolean indicator which, if true, indicates that the target for the visit                is an internal calibration
#       target.'}
# - name: visit_nexposures
#   datatype: int64
#   meta: !!omap
#   - {description: The total number of exposures planned within the visit.}
# - name: visit_type
#   datatype: string
#   meta: !!omap
#   - {description: The type of visit from observation planning.}
# - name: vparity
#   datatype: int64
#   meta: !!omap
#   - {description: Relative sense of rotation between the ideal and telescope coordinate                systems. The value may be either
#       1 or -1. This information comes from the Science                Instrument Aperture File (SIAF) in the Science Operations Center
#       (SOC) Project                Reference Database (PRD). See documents STScI-JWST-001550 and STScI-Roman-000143 for                more
#       information.}
# - name: wfi_parallel
#   datatype: string
#   meta: !!omap
#   - {description: 'A boolean flag that, when true, indicates the WFI was operated in parallel                with the Coronagraph as
#       the prime observing instrument. If false, the WFI was                operated as the prime observing instrument.'}
# - name: window_xstart
#   datatype: int64
#   meta: !!omap
#   - {description: Minimum X position in pixels in the science coordinate frame of all                tracking guide windows in this
#       exposure.}
# - name: window_xstop
#   datatype: int64
#   meta: !!omap
#   - {description: Maximum X position in pixels in the science coordinate frame of all                tracking guide windows in this
#       exposure.}
# - name: window_ystart
#   datatype: int64
#   meta: !!omap
#   - {description: Minimum Y position in pixels in the science coordinate frame of all                tracking guide windows in this
#       exposure.}
# - name: window_ystop
#   datatype: int64
#   meta: !!omap
#   - {description: Maximum Y position in pixels in the science coordinate frame of all                tracking guide windows in this
#       exposure.}
# - name: zodiacal_light
#   datatype: float64
#   meta: !!omap
#   - {description: A model estimate of the Zodiacal light contribution to the sky background                in units of MegaJanskys per
#       steradian (MJy/sr).}
# - name: catalog_id
#   datatype: int64
#   meta: !!omap
#   - {description: Unique ID number for this catalog}
# - name: cdp_ctx
#   datatype: int64
#   meta: !!omap
#   - {description: CDP Context for calibration files}
# - name: dither
#   datatype: float64
#   meta: !!omap
#   - {description: Dither position id. Example value '1'}
# - name: file_number
#   datatype: int64
#   meta: !!omap
#   - {description: 'File number for this catalog file (e.g., 1)'}
# - name: g2dp_run_id
#   datatype: string
#   meta: !!omap
#   - {description: ID of the G2DP run that created the G2DP file(s). Example value '42'}
# - name: num_src
#   datatype: int64
#   meta: !!omap
