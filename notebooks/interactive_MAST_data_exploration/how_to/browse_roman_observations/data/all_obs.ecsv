# - name: phot_filter_cut_off
#   datatype: string
#   meta: !!omap
#   - {description: The filter used for the G2DP magnitude cut off. Example value 'F158'}
# - name: program_complete
#   datatype: string
#   meta: !!omap
#   - {description: Identifies if this observation program is finished. Example value 'False'}
# - name: unit_flux
#   datatype: string
